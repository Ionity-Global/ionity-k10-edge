# IonityEdge · K10 — Edge Brain configuration (copy to .env)
# © Ionity (Pty) Ltd · Policy 986 AED

EDGE_HOST=0.0.0.0
EDGE_PORT=8765

# Feature flags
FEAT_VISION=1
FEAT_OCR=1
FEAT_VOICE=1
FEAT_MOOD=1
FEAT_GEO=1
FEAT_RECORDING=1
FEAT_ADS=1

# Semantic cache
CACHE_THRESHOLD=0.92
CACHE_MAX=5000

# Local LLM (Ollama)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2

# Claude-desktop bridge (relays into Claude on YOUR PC via YOUR Google login — no API key).
# Modes: off | http   (http => a local companion relay you run; see bridge/claude_desktop.py)
BRIDGE_MODE=off
BRIDGE_URL=http://127.0.0.1:8799/ask
BRIDGE_MIN_CONFIDENCE=0.55   # escalate to bridge when local confidence is below this

# Optional local integrations (all off by default — LOCAL SAVED, no cloud)
# Home-Assistant style webhook that /api/dispatch forwards commands to:
DISPATCH_WEBHOOK_URL=
# Local image backend (A1111 / ComfyUI) that /api/generate-image relays prompts to;
# empty => /api/generate-image returns a real procedural mood-orb SVG instead:
IMAGE_API_URL=
# Path to a Piper .onnx voice to enable server-side /api/speak (WAV); empty => browser TTS:
PIPER_VOICE=

# Storage (LOCAL SAVED)
DATA_DIR=./data
RECORDINGS_DIR=./recordings
MODELS_DIR=./models
