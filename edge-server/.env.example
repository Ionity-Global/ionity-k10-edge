# IonityEdge · K10 — Edge Brain configuration (copy to .env)
# © Ionity (Pty) Ltd · Policy 986 AED

EDGE_HOST=0.0.0.0
EDGE_PORT=8765

# Feature flags
FEAT_VISION=1
FEAT_OCR=1
FEAT_VOICE=1
FEAT_MOOD=1
FEAT_GEO=1
FEAT_RECORDING=1
FEAT_ADS=1

# Semantic cache
CACHE_THRESHOLD=0.92
CACHE_MAX=5000

# Local LLM (Ollama) — fallback brain
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b        # installed; gemma4:e4b / gemma3:4b also available

# Claude web bridge (relays to claude.ai via YOUR Google login — no API key). PRIMARY brain.
# Run bridge/claude-web (START-BRIDGE.bat), sign in once. Modes: off | http
BRIDGE_MODE=http
BRIDGE_URL=http://127.0.0.1:8799/ask
BRIDGE_MIN_CONFIDENCE=0.55

# ---- Voice home-assistant ----
ASSIST_ENABLED=1
WAKE_WORD=peper                # say "Peper" to wake + listen (server-side, on the edge)
ASSISTANT_NAME=Peper
ORB_STREAM_FPS=10
ORB_FRAME_SIZE=150
IDLE_SLEEP_S=30
TTS_VOICE=                     # Piper .onnx path; empty => auto-discovers models/piper/*.onnx (fluent voice)

# ---- Smart home (all optional — configure what you have) ----
HA_URL=                        # e.g. http://homeassistant.local:8123
HA_TOKEN=                      # Home Assistant long-lived access token
HUE_BRIDGE=                    # Philips Hue bridge IP (press the button on first connect)
CHROMECAST_NAME=               # default Cast / Android TV device name
MQTT_HOST=                     # MQTT broker for ESP32 / IoT devices
MQTT_PORT=1883

# Optional local integrations (all off by default — LOCAL SAVED, no cloud)
# Home-Assistant style webhook that /api/dispatch forwards commands to:
DISPATCH_WEBHOOK_URL=
# Local image backend (A1111 / ComfyUI) that /api/generate-image relays prompts to;
# empty => /api/generate-image returns a real procedural mood-orb SVG instead:
IMAGE_API_URL=
# Path to a Piper .onnx voice to enable server-side /api/speak (WAV); empty => browser TTS:
PIPER_VOICE=

# Storage (LOCAL SAVED)
DATA_DIR=./data
RECORDINGS_DIR=./recordings
MODELS_DIR=./models
